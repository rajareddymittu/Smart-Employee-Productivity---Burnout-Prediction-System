@startuml
title AI-Powered Employee Productivity Analytics and Burnout Prediction System
left to right direction

skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
    BackgroundColor White
    BorderColor Black
}

actor Employee
actor Manager
actor HR
actor Admin

rectangle "AI-Powered Employee Productivity Analytics & Burnout Prediction System" {

  usecase "Login" as UC1
  usecase "Logout" as UC2
  usecase "View Dashboard" as UC3
  usecase "Update Profile" as UC4

  usecase "Submit Worklog" as UC5
  usecase "View My Worklogs" as UC6
  usecase "View My Attendance" as UC7
  usecase "Apply Leave" as UC8
  usecase "View My Tasks" as UC9
  usecase "View My Meetings" as UC10
  usecase "View Performance Reviews" as UC11
  usecase "View Burnout Prediction" as UC12

  usecase "View Team Members" as UC13
  usecase "Approve Leave Requests" as UC14
  usecase "Review Team Worklogs" as UC15
  usecase "Assign Tasks" as UC16
  usecase "Schedule Meetings" as UC17
  usecase "Review Burnout Reports" as UC18

  usecase "Manage Employees" as UC19
  usecase "Manage Departments" as UC20
  usecase "Manage Attendance" as UC21
  usecase "Manage Leave Types" as UC22
  usecase "Manage Projects" as UC23
  usecase "Generate Reports" as UC24
  usecase "Run Burnout Prediction" as UC25
  usecase "View Analytics Dashboard" as UC26
  usecase "Manage Notifications" as UC27

  usecase "Manage Users" as UC28
  usecase "Manage Roles" as UC29
  usecase "View Audit Logs" as UC30
  usecase "System Configuration" as UC31

}

